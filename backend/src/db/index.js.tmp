
  // 精英起爆2026预警表初始化
  this.db.run(`
    CREATE TABLE IF NOT EXISTS elite_2026_alerts (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      code TEXT NOT NULL,
      name TEXT NOT NULL,
      current_price REAL,
      created_at DATE DEFAULT (date('now'))
    )
  `);

  // 检查今天是否已推送过
  this.checkElite2026AlertSentToday = async function(code) {
    return new Promise((resolve, reject) => {
      this.db.get(
        `SELECT id FROM elite_2026_alerts WHERE code = ? AND created_at = date('now')`,
        [code],
        (err, row) => {
          if (err) reject(err);
          else resolve(!!row);
        }
      );
    });
  };

  // 记录精英起爆2026预警
  this.recordElite2026Alert = async function(code, name, currentPrice) {
    return new Promise((resolve, reject) => {
      this.db.run(
        `INSERT INTO elite_2026_alerts (code, name, current_price) VALUES (?, ?, ?)`,
        [code, name, currentPrice],
        function(err) {
          if (err) reject(err);
          else resolve({ id: this.lastID });
        }
      );
    });
  };
